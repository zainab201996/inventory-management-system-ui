        "page_name": "Business Plan Start",
        "slug": "business-plan-start",
        "description": null,
        "is_report": false,
        "is_action": true,
        "created_at": "2024-01-01T00:00:00.000Z"
      }
    ],
    "pagination": {
      "page": 1,
      "limit": 10,
      "total": 5,
      "total_pages": 1
    }
  }
}
```

**Response (with all=true):**
```json
{
  "success": true,
  "message": "Pages retrieved successfully",
  "data": [
    {
      "page_id": 1,
      "page_name": "Business Plans",
      "slug": "business-plans",
      "is_report": false,
      "is_action": false,
      "created_at": "2024-01-01T00:00:00.000Z"
    },
    {
